{
  "name": "telegram-mention-bot",
  "version": "1.0.0",
  "description": "Telegram bot that mentions all group members on /hamma or /all commands",
  "main": "dist/bot.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/bot.js",
    "dev": "ts-node-dev --respawn --transpile-only src/bot.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "telegram",
    "bot",
    "mention"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^16.0.0",
    "grammy": "^1.30.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
